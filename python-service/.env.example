# Copy to .env and fill in real values
# See docs/ENV.md for where each value comes from

# Must match the value in /web/.env.local
PYTHON_SERVICE_SECRET=

# Supabase — from Dashboard → Settings → API
# Format: https://<project-ref>.supabase.co  (NOT the dashboard URL)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of allowed origins
# In production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Provided automatically by Railway in production
PORT=8000
